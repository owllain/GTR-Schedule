generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Staff {
  id                    String   @id @default(cuid())
  nombre                String
  apellido              String
  finDeSemanaPreferente String   @default("MIXTO")  // MIXTO, SABADO, DOMINGO
  proformaId            String?  // Optional link to proforma template
  activo                Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  scheduleEntries ScheduleEntry[]
  novedades       Novedad[]
  proforma        Proforma?  @relation(fields: [proformaId], references: [id], onDelete: SetNull)
}

model Proforma {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entradas ProformaEntry[]
  staff    Staff[]
}

model ProformaEntry {
  id          String   @id @default(cuid())
  proformaId  String
  diaSemana   Int      // 0=Dom, 1=Lun, 2=Mar, 3=Mie, 4=Jue, 5=Vie, 6=Sab
  horaEntrada String   // HH:mm format
  horaSalida  String   // HH:mm format
  esDescanso  Boolean  @default(false) // true = day off
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  proforma Proforma @relation(fields: [proformaId], references: [id], onDelete: Cascade)
}

model ScheduleEntry {
  id        String   @id @default(cuid())
  staffId   String
  date      String   // YYYY-MM-DD format
  entryTime String   @default("") // HH:mm format
  exitTime  String   @default("") // HH:mm format
  hours     Float    @default(0)  // Calculated hours
  type      String   @default("NORMAL") // NORMAL, VACACION, INCAPACIDAD, LICENCIA, PERMISO, FERIADO, DESCANSO
  notes     String?
  isWeekend Boolean  @default(false)
  isManual  Boolean  @default(false) // If manually edited
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
}

model Novedad {
  id          String   @id @default(cuid())
  staffId     String
  startDate   String   // YYYY-MM-DD
  endDate     String   // YYYY-MM-DD
  type        String   // VACACION, INCAPACIDAD, LICENCIA, PERMISO, FERIADO
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)
}
